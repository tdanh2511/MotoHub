<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFF5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="18dp"
        android:paddingTop="28dp"
        android:paddingEnd="18dp"
        android:paddingBottom="16dp"
        android:background="#D32F2F">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnBack"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:padding="10dp"
            android:contentDescription="Back"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:insetLeft="0dp"
            android:insetRight="0dp"
            app:icon="@drawable/ic_arrow_back"
            app:iconTint="#FFFFFF"
            app:iconSize="22dp"
            app:backgroundTint="@android:color/transparent"
            app:strokeWidth="0dp"
            app:rippleColor="#33FFFFFF" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="10dp"
            android:paddingEnd="10dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Quản lý hãng xe"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Thêm, sửa, xóa hãng xe"
                android:textSize="12sp"
                android:textColor="#FFE0E0" />
        </LinearLayout>

        <Button
            android:id="@+id/btnAddBrand"
            android:layout_width="wrap_content"
            android:layout_height="42dp"
            android:layout_gravity="center_vertical"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:text="+ Thêm"
            android:textAllCaps="false"
            android:textSize="14sp"
            android:textStyle="bold"
            android:backgroundTint="#FFFFFF"
            android:textColor="#D32F2F" />
    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="22dp"
        android:layout_marginEnd="16dp"
        android:text="Danh sách hãng xe"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#B71C1C" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="4dp"
        android:layout_marginEnd="16dp"
        android:text="Quản lý các hãng xe hiện có trong hệ thống"
        android:textSize="13sp"
        android:textColor="#777777" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerViewBrands"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="12dp"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:paddingBottom="12dp"
        android:clipToPadding="false" />

</LinearLayout>