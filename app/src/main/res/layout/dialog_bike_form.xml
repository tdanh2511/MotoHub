<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Thông tin xe"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#D32F2F"
            android:layout_marginBottom="16dp" />

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:boxBackgroundMode="outline"
            app:boxStrokeColor="#D32F2F"
            app:hintTextColor="#D32F2F">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etBikeName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Tên xe *"
                android:inputType="text" />
        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Hãng xe *"
            android:textStyle="bold"
            android:textColor="#D32F2F"
            android:layout_marginBottom="6dp" />

        <Spinner
            android:id="@+id/spinnerBrand"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="12dp"
            android:background="@android:drawable/editbox_background" />

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:boxBackgroundMode="outline"
            app:boxStrokeColor="#D32F2F"
            app:hintTextColor="#D32F2F"
            app:prefixText="đ ">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etBikePrice"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Giá xe *"
                android:inputType="numberDecimal" />
        </com.google.android.material.textfield.TextInputLayout>

        <ImageView
            android:id="@+id/imgBikePreview"
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:layout_marginBottom="12dp"
            android:background="#EEEEEE"
            android:scaleType="fitCenter"
            android:src="@android:drawable/ic_menu_gallery" />

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:boxBackgroundMode="outline"
            app:boxStrokeColor="#D32F2F"
            app:hintTextColor="#D32F2F">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etBikeImage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Tên ảnh drawable, ví dụ: honda_sh_160i"
                android:inputType="text"
                android:focusable="true"
                android:clickable="true" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPreviewImage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Xem ảnh"
            android:textAllCaps="false"
            android:layout_marginBottom="12dp"
            android:backgroundTint="#D32F2F"
            android:textColor="#FFFFFF" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="* Nhập đúng tên file ảnh trong drawable, không cần .png/.jpg"
            android:textSize="12sp"
            android:textColor="#666666"
            android:textStyle="italic" />

    </LinearLayout>
</ScrollView>