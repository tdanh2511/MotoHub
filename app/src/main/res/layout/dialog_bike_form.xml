<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🏍️ Thông tin xe"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#D32F2F"
            android:layout_marginBottom="16dp" />

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:boxBackgroundMode="outline"
            app:boxStrokeColor="#D32F2F"
            app:hintTextColor="#D32F2F">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etBikeName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Tên xe *"
                android:inputType="text" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:boxBackgroundMode="outline"
            app:boxStrokeColor="#D32F2F"
            app:hintTextColor="#D32F2F">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etBikeBrand"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Hãng xe *"
                android:inputType="text" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:boxBackgroundMode="outline"
            app:boxStrokeColor="#D32F2F"
            app:hintTextColor="#D32F2F"
            app:prefixText="đ ">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etBikePrice"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Giá xe *"
                android:inputType="numberDecimal" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:boxBackgroundMode="outline"
            app:boxStrokeColor="#D32F2F"
            app:hintTextColor="#D32F2F">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etBikeImage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Tên ảnh (không có đuôi)"
                android:inputType="text" />
        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="* Bắt buộc nhập"
            android:textSize="12sp"
            android:textColor="#666666"
            android:textStyle="italic" />

    </LinearLayout>
</ScrollView>
