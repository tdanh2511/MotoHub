<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.MotoHub">
        <activity android:name=".activities.auth.RegisterActivity" />
        <activity android:name=".activities.auth.LoginActivity" />
        <activity android:name=".activities.admin.AdminHomeActivity" />
        <activity android:name=".activities.admin.ManageBikesActivity" />
        <activity android:name=".activities.admin.ManageUsersActivity" />
        <activity android:name=".activities.admin.ManageRevenueActivity" />
        <activity android:name=".activities.user.HomeActivity" />
        <activity android:name=".activities.user.ProfileActivity" />
        <activity android:name=".activities.user.PersonalInfoActivity" />
        <activity android:name=".activities.user.ChangePasswordActivity"/>
        <activity android:name=".activities.user.PrivacyPolicyActivity" />
        <activity android:name=".activities.user.WarrantyPolicyActivity" />
        <activity android:name=".activities.user.GuideActivity"/>
        <activity android:name=".activities.user.SupportActivity" />
        <activity android:name=".activities.user.SearchActivity" />
        <activity android:name=".activities.user.MotorbikeDetailActivity" />
        <activity android:name=".activities.user.CartActivity" />
        <activity android:name=".activities.user.FavoritesActivity" />
        <activity android:name=".activities.user.CheckoutActivity" />
        <activity android:name=".activities.user.OrderHistoryActivity" />
        <activity android:name=".activities.user.OrderDetailActivity" />
        <activity android:name=".activities.admin.ManageBrandsActivity" />
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.MotoHub.Starting">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>

</manifest>